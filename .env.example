# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values for your environment:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must NEVER be committed — it holds resource IDs
# and (optionally) secrets specific to your Azure subscription.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AI Foundry (required) ──
# Full endpoint URL of your Azure AI Foundry project.
PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>
# Name of the deployed model to use.
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# ── Azure Storage (required) ──
# Storage account used to persist rendered images and downloads.
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account-name>

# ── Blender socket server (optional) ──
# BLENDER_HOST=localhost
# BLENDER_PORT=9876

# ── Logging (optional) ──
# One of: DEBUG, INFO, WARNING, ERROR
BLENDER_AGENT_LOG_LEVEL=INFO

# ── Voice: speech-in / speech-out (optional) ──
# Turn the voice path on/off. Voice only activates when Speech is configured below.
ENABLE_VOICE=true
# Azure Speech / AI Services region (e.g. northcentralus).
SPEECH_REGION=<your-speech-region>
# Keyless auth (recommended): resource ID of the Speech / AI Services resource.
# Grant the agent's identity the "Cognitive Services User" role on this resource.
SPEECH_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>
# Alternative to keyless auth: a Speech resource key (leave unset if using SPEECH_RESOURCE_ID).
# SPEECH_KEY=<your-speech-key>
# TTS voice overrides (optional).
# SPEECH_VOICE_NAME=en-US-NovaMultilingualNeuralHD
# SPEECH_VOICE_FALLBACK=en-US-AvaMultilingualNeural
# Port for the voice WebSocket (invocations_ws).
# VOICE_WS_PORT=8089

# ── Azure credentials (optional) ──
# Only needed for local Docker runs when you are NOT mounting ~/.azure.
# AZURE_CLIENT_ID=<app-registration-client-id>
# AZURE_TENANT_ID=<your-tenant-id>
# AZURE_CLIENT_SECRET=<client-secret>
