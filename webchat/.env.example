# Agent endpoint mode: "local" or "foundry"
AGENT_MODE=local

# Local agent base URL (when AGENT_MODE=local)
AGENT_LOCAL_URL=http://localhost:8088

# Foundry project endpoint (when AGENT_MODE=foundry).
# This is the project root; the proxy appends /agents/<AGENT_NAME>/...
# Example: https://<acct>.services.ai.azure.com/api/projects/<project>
AGENT_FOUNDRY_URL=

# Hosted agent name (required when AGENT_MODE=foundry).
AGENT_NAME=fantasy-worlds-agent

# Foundry control-plane API version (defaults to v1).
AGENT_API_VERSION=v1

# Token scope for Foundry mode. Override to https://cognitiveservices.azure.com/.default if 401.
AGENT_TOKEN_SCOPE=https://ai.azure.com/.default

# Value sent as the `model` field in the Responses request body.
# Local: typically the agent name from agent.yaml (BlenderSceneAgent).
# Foundry: cosmetic — Foundry resolves the model from the agent definition.
MODEL_NAME=BlenderSceneAgent

# Proxy server port
PORT=5174
