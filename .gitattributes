# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Ensure these always have LF endings (critical for Docker/Linux execution)
*.sh text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
entrypoint.sh text eol=lf

# Binary files — do not touch
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.blend binary
*.zip binary
*.tar.gz binary
